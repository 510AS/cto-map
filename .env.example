# PostgreSQL connection string (pooled connection for serverless)
# For Vercel Postgres / Neon: use the pooled connection URL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require&pgbouncer=true"

# Direct connection (non-pooled, used for migrations)
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Seed file path (only needed for local seeding)
SEED_HTML_PATH="../technical_cto_mastery_final.html"
